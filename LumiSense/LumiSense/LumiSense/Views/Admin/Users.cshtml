@model List<LumiSense.Controllers.AdminController.AdminUserRow>
@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Admin_UsersTitle"].Value;
}

<div class="uv-card">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
        <h2 style="margin:0;">@L["Admin_UsersTitle"]</h2>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="buy-btn" style="text-decoration:none;" href="/Admin/Orders">@L["Admin_OrdersTitle"]</a>
            <a class="buy-btn" style="text-decoration:none;" href="/Admin/Reviews">@L["Admin_ReviewsTitle"]</a>
        </div>
    </div>

    <div style="margin-top:1rem; overflow:auto;">
        <table class="table" style="width:100%; background:white; border-radius:12px; overflow:hidden;">
            <thead>
                <tr>
                    <th style="text-align:left; padding:12px;">@L["Admin_UserEmail"]</th>
                    <th style="text-align:left; padding:12px;">@L["Admin_UserPhone"]</th>
                    <th style="text-align:left; padding:12px;">@L["Admin_UserRoles"]</th>
                    <th style="text-align:left; padding:12px;">@L["Admin_UserLockout"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td style="padding:12px;">
                        <div style="font-weight:900;">@u.Email</div>
                        <div style="color:#777; font-size:0.85rem;">@u.Id</div>
                    </td>
                    <td style="padding:12px;">@(string.IsNullOrWhiteSpace(u.PhoneNumber) ? "—" : u.PhoneNumber)</td>
                    <td style="padding:12px;">
                        @if (u.IsAdmin)
                        {
                            <span style="background:#e9f7ef; border:1px solid #bfe5cf; color:#1d6b3a; padding:2px 8px; border-radius:999px; font-weight:900; font-size:0.85rem;">
                                Admin
                            </span>
                        }
                        else
                        {
                            <span style="background:#f4f5f7; border:1px solid rgba(0,0,0,0.08); color:#555; padding:2px 8px; border-radius:999px; font-weight:900; font-size:0.85rem;">
                                User
                            </span>
                        }
                    </td>
                    <td style="padding:12px;">
                        @if (u.LockoutEnd.HasValue && u.LockoutEnd.Value > DateTimeOffset.UtcNow)
                        {
                            <span style="background:#fff3cd; border:1px solid #ffe69c; color:#8a6d3b; padding:2px 8px; border-radius:999px; font-weight:900; font-size:0.85rem;">
                                @L["Admin_LockedUntil"] @u.LockoutEnd.Value.ToLocalTime().ToString("g")
                            </span>
                        }
                        else
                        {
                            <span style="color:#777;">—</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

