@using LumiSense.Models
@model IEnumerable<ProductListItemViewModel>
@using System.Text.Json
@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Shop_Title"].Value;
}

<style>
    .hero {
        text-align: center;
        padding: 3rem 1rem;
        color: white;
        border-radius: 0 0 20px 20px;
    }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        padding: 2rem;
    }

    .product-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        text-align: center;
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
        }

    .product-icon {
        font-size: 3rem;
        margin-bottom: 10px;
        color: #F27121;
    }

    .product-title {
        font-size: 1.3rem;
        font-weight: bold;
    }

    .product-desc {
        font-size: 0.9rem;
        color: gray;
        margin: 10px 0;
    }

    .product-price {
        font-size: 1.2rem;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .stock-in {
        color: green;
    }

    .stock-out {
        color: red;
    }

    .buy-btn {
        background: linear-gradient(135deg, #F27121, #F9A826);
        border: none;
        padding: 10px 15px;
        border-radius: 10px;
        color: white;
        cursor: pointer;
        margin-top: 10px;
    }

        .buy-btn:disabled {
            background: gray;
            cursor: not-allowed;
        }

    .modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: white;
        padding: 20px;
        border-radius: 20px;
        width: 350px;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .close-modal {
        cursor: pointer;
        font-size: 20px;
    }

    .form-group {
        margin: 10px 0;
    }

        .form-group input {
            width: 100%;
            padding: 8px;
        }

    .modal-footer {
        display: flex;
        justify-content: space-between;
        margin-top: 15px;
    }

    .order-btn {
        background: green;
        color: white;
        padding: 8px 12px;
        border: none;
        border-radius: 10px;
    }

    .cancel-btn {
        background: red;
        color: white;
        padding: 8px 12px;
        border: none;
        border-radius: 10px;
    }

   
 
</style>

<div class="hero" style="background: linear-gradient(135deg, #F27121, #F9A826);">
    <h1><i class="fas fa-store"></i> @L["Shop_HeroTitle"]</h1>
    <p>@L["Shop_HeroSubtitle"]</p>
</div>

<div style="max-width:1200px; margin:0 auto; padding:0 2rem;">
    <div class="uv-card" style="background:#fff; padding:12px 14px; margin:0 auto 10px; border:1px solid rgba(0,0,0,0.06);">
        <form method="get" action="/Shop" style="display:flex; gap:12px; align-items:center; justify-content:space-between; flex-wrap:wrap; margin:0;">
            <div style="font-weight:950; display:flex; align-items:center; gap:8px;">
                <i class="fas fa-filter" style="color:#F27121;"></i> @L["Shop_SortProducts"]
            </div>
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                @{
                    var sort = (ViewData["Sort"]?.ToString() ?? string.Empty);
                }
                <select class="form-control" name="sort" style="min-width:240px;">
                    @if (string.IsNullOrWhiteSpace(sort))
                    {
                        <option value="" selected>@L["Shop_SortPopular"]</option>
                    }
                    else
                    {
                        <option value="">@L["Shop_SortPopular"]</option>
                    }

                    @if (sort == "price_asc")
                    {
                        <option value="price_asc" selected>@L["Shop_SortPriceAsc"]</option>
                    }
                    else
                    {
                        <option value="price_asc">@L["Shop_SortPriceAsc"]</option>
                    }

                    @if (sort == "price_desc")
                    {
                        <option value="price_desc" selected>@L["Shop_SortPriceDesc"]</option>
                    }
                    else
                    {
                        <option value="price_desc">@L["Shop_SortPriceDesc"]</option>
                    }

                    @if (sort == "rating_desc")
                    {
                        <option value="rating_desc" selected>@L["Shop_SortTopRated"]</option>
                    }
                    else
                    {
                        <option value="rating_desc">@L["Shop_SortTopRated"]</option>
                    }

                    @if (sort == "reviews_desc")
                    {
                        <option value="reviews_desc" selected>@L["Shop_SortMostReviewed"]</option>
                    }
                    else
                    {
                        <option value="reviews_desc">@L["Shop_SortMostReviewed"]</option>
                    }
                </select>
                <button type="submit" class="buy-btn" style="margin-top:0;">
                    @L["Common_Apply"]
                </button>
            </div>
        </form>
    </div>
</div>

<div class="products-grid">
    @foreach (var item in Model)
    {
        var product = item.Product;
    var tName = L[$"Product_{product.Id}_Name"];
    var tDesc = L[$"Product_{product.Id}_Description"];
    var productName = tName.ResourceNotFound ? product.Name : tName.Value;
    var productDesc = tDesc.ResourceNotFound ? product.Description : tDesc.Value;
        <div class="product-card">
            <div class="product-icon">
                <i class="fas @product.ImageIcon"></i>
            </div>
            <div class="product-info">
                    <div class="product-title">
                        <a href="/Shop/Product/@product.Id" style="text-decoration:none; color:inherit;">@productName</a>
                    </div>
                <div class="product-desc">@productDesc</div>
                <div class="product-price">$@product.Price.ToString("F2")</div>
                <div style="margin-top:6px; color:#F27121; font-size:0.95rem;">
                    @{
                        var stars = (int)Math.Round(item.AvgRating, MidpointRounding.AwayFromZero);
                        if (item.ApprovedReviewCount == 0) { stars = 0; }
                    }
                    @for (var i = 1; i <= 5; i++)
                    {
                        if (i <= stars)
                        {
                            <i class="fas fa-star"></i>
                        }
                        else
                        {
                            <i class="far fa-star" style="opacity:0.55;"></i>
                        }
                    }
                    <span style="color:#666; margin-left:8px;">
                        (@item.ApprovedReviewCount)
                    </span>
                </div>

                @if (product.Stock > 0)
                {
                    <div class="product-stock stock-in">@string.Format(L["Shop_InStock"].Value, product.Stock)</div>
                    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:10px;">
                        <a class="buy-btn" style="text-decoration:none; display:inline-block; margin-top:0;"
                           href="/Cart/BuyNow?productId=@product.Id&amp;quantity=1">
                            @L["Shop_BuyNow"] <i class="fas fa-shopping-cart"></i>
                        </a>
                        <a class="cancel-btn" style="text-decoration:none; display:inline-block; margin-top:0;"
                           href="/Shop/Product/@product.Id">
                            <i class="fas fa-circle-info"></i> @L["Shop_Details"]
                        </a>
                    </div>
                }
                else
                {
                    <div class="product-stock stock-out">@L["Shop_OutOfStock"]</div>
                    <button class="buy-btn" disabled>@L["Shop_SoldOut"]</button>
                }
            </div>
        </div>
    }
</div>

<div id="orderModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>@L["Shop_PlaceOrder"]</h3>
            <span class="close-modal" onclick="closeModal()">&times;</span>
        </div>

        <input type="hidden" id="productId">

        <div class="form-group">
            <label>@L["Shop_YourName"]</label>
            <input type="text" id="customerName" placeholder="@L["Shop_EnterYourName"]">
        </div>

        <div class="form-group">
            <label>@L["Shop_EmailRequired"]</label>
            <input type="email" id="customerEmail" placeholder="@L["Shop_EnterYourEmail"]">
        </div>

        <div class="form-group">
            <label>@L["Shop_Quantity"]</label>
            <input type="number" id="quantity" value="1" min="1">
        </div>

        <div style="background: #f0f0f0; padding: 1rem; border-radius: 10px;">
            <strong>@L["Shop_Product"]</strong> <span id="modalProductName"></span><br>
            <strong>@L["Shop_Price"]</strong> $<span id="modalProductPrice"></span> @L["Shop_Each"]
        </div>

        <div class="modal-footer">
            <button class="cancel-btn" onclick="closeModal()">@L["Shop_Cancel"]</button>
            <button class="order-btn" onclick="placeOrder()">@L["Shop_PlaceOrderButton"]</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const tFillAllFields = @JsonSerializer.Serialize(L["Shop_FillAllFieldsAlert"].Value);
        const tErrorPlacingOrder = @JsonSerializer.Serialize(L["Shop_ErrorPlacingOrder"].Value);
        const tAddedToCart = @JsonSerializer.Serialize(L["Shop_AddedToCart"].Value);
        const tAddToCartFailed = @JsonSerializer.Serialize(L["Shop_AddToCartFailed"].Value);

        async function buyNow(productId) {
            try {
                const res = await fetch('/Cart/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, quantity: 1 })
                });
                const data = await res.json().catch(() => null);
                if (!res.ok || !data || !data.success) {
                    alert(tAddToCartFailed);
                    return;
                }
                // Optional feedback
                // alert(tAddedToCart);
                window.location.href = '/Cart';
            } catch {
                alert(tAddToCartFailed);
            }
        }

        function closeModal() {
            document.getElementById('orderModal').style.display = 'none';
        }

        async function placeOrder() {
            const customerName = document.getElementById('customerName').value;
            const customerEmail = document.getElementById('customerEmail').value;
            const quantity = parseInt(document.getElementById('quantity').value);
            const productId = parseInt(document.getElementById('productId').value);

            if (!customerName || !customerEmail) {
                alert(tFillAllFields);
                return;
            }

            const formData = new FormData();
            formData.append('customerName', customerName);
            formData.append('customerEmail', customerEmail);
            formData.append('productId', productId);
            formData.append('quantity', quantity);

            try {
                const response = await fetch('/Shop/PlaceOrder', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });

                if (response.status === 401) {
                    window.location.href = '/Identity/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                    return;
                }
                if (response.status === 403) {
                    alert(@JsonSerializer.Serialize(L["Common_AccessDenied"].Value));
                    return;
                }

                const result = await response.json().catch(() => null);
                if (!result) {
                    alert(tErrorPlacingOrder);
                    return;
                }

                if (result.success) {
                    alert(result.message);
                    closeModal();
                    location.reload();
                } else {
                    alert(result.message || tErrorPlacingOrder);
                }
            } catch {
                alert(tErrorPlacingOrder);
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('orderModal');
            if (event.target === modal) {
                closeModal();
            }
        };
    </script>
}