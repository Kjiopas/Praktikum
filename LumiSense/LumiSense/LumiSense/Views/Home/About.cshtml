@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["About_Title"].Value;
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f5f6fa !important; }
        .hero {
            background: linear-gradient(135deg, #4f46e5, #9333ea);
            color: white;
            padding: 60px 30px;
            border-radius: 20px;
            margin: 30px auto;
        }
        .features {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-top: -35px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .about img {
            border-radius: 15px;
            height: 200px;
            object-fit: cover;
        }
        .btn-custom {
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
        }
    </style>
}

<div class="container text-center">
    <div class="about mt-4">
        <h1 class="fw-bold">@L["About_Heading"]</h1>
        <h5 class="text-muted">@L["About_Subheading"]</h5>

        <p class="mt-3">
            @L["About_Body"]
        </p>

        <div class="row mt-4 g-3">
            <div class="col-md-4">
                <img src="~/images/home-about-1.svg" class="img-fluid" alt="UV monitoring illustration">
            </div>
            <div class="col-md-4">
                <img src="~/images/home-about-2.svg" class="img-fluid" alt="Location and analytics illustration">
            </div>
            <div class="col-md-4">
                <img src="~/images/home-about-3.svg" class="img-fluid" alt="Protection gear illustration">
            </div>
        </div>

        <div class="mt-4">
            <a href="/LiveUV" class="btn btn-primary btn-custom">@L["About_Cta1"]</a>
            <a href="/Shop" class="btn btn-light btn-custom">@L["About_Cta2"]</a>
        </div>
    </div>
</div>

