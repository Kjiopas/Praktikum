@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Home_Title"].Value;
}

<div class="hero" style="background: linear-gradient(135deg, #667eea, #764ba2); text-align: center; padding: 80px 20px;">
    <i class="fas fa-microchip" style="font-size: 4rem; color: #F27121; margin-bottom: 1rem;"></i>
    <h1>@L["Home_HeroTitle"]</h1>
    <p>@L["Home_HeroSubtitle"]</p>
    <a href="/LiveUV" class="refresh-btn" style="display: inline-block; margin-top: 20px;">
        <i class="fas fa-chart-line"></i> @L["Home_CheckUvNow"]
    </a>
</div>