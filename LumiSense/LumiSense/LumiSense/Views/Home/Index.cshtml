@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Home_Title"].Value;
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f5f6fa !important; }

        .hero {
            background: linear-gradient(135deg, #4f46e5, #9333ea);
            color: white;
            padding: 80px 30px;
            border-radius: 20px;
            margin: 30px auto;
            position: relative;
            overflow: hidden;
        }

        .hero::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url("/images/home-hero.svg");
            background-size: cover;
            background-position: center;
            opacity: 0.18;
            transform: scale(1.02);
        }

        .hero > * { position: relative; z-index: 1; }

        .btn-custom {
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
        }

        .features {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-top: -40px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .about img {
            border-radius: 15px;
            height: 200px;
            object-fit: cover;
        }
    </style>
}

<div class="container text-center">

    <!-- HERO -->
    <div class="hero">
        <h1 class="fw-bold">@L["Home_HeroTitle"]</h1>
        <p class="mt-3">
            @L["Home_HeroSubtitle"]
        </p>

        <div class="mt-4">
            <a href="/LiveUV" class="btn btn-primary btn-custom">@L["Home_CheckUvNow"]</a>
            <a href="/Shop" class="btn btn-light btn-custom">@L["Home_SecondaryCta"]</a>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="features row text-center g-3">
        <div class="col-md-4">
            <h4>@L["Home_Feature1Emoji"] @L["Home_Feature1Title"]</h4>
            <p>@L["Home_Feature1Body"]</p>
        </div>
        <div class="col-md-4">
            <h4>@L["Home_Feature2Emoji"] @L["Home_Feature2Title"]</h4>
            <p>@L["Home_Feature2Body"]</p>
        </div>
        <div class="col-md-4">
            <h4>@L["Home_Feature3Emoji"] @L["Home_Feature3Title"]</h4>
            <p>@L["Home_Feature3Body"]</p>
        </div>
    </div>

</div>