@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L
@model LumiSense.Models.HomeViewModel
@{
    ViewData["Title"] = L["Live_Title"].Value;
    var currentUv = Model?.Statistics?.CurrentUV ?? 0;
    var avgUv = Model?.Statistics?.AverageUV ?? 0;
    var peakUv = Model?.Statistics?.MaxUVToday ?? 0;
    var peakTime = Model?.Statistics?.PeakTime ?? "N/A";
    var readingsCount = Model?.Statistics?.ReadingsCount ?? 0;
    var location = Model?.CurrentReading?.Location ?? L["Live_LocationDefault"].Value;
    var timestamp = (Model?.CurrentReading?.Timestamp ?? DateTime.Now).ToString("HH:mm:ss");
    var rec = Model?.SafetyRecommendation;
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .solar-shell {
            background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.82));
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 18px;
            box-shadow: 0 14px 34px rgba(0,0,0,0.12);
        }

        .solar-card {
            background: rgba(255,255,255,0.92);
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 10px 24px rgba(0,0,0,0.08);
        }

        .help-muted {
            color: rgba(17,24,39,0.60);
            font-size: 0.9rem;
        }

        .pill-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 999px;
            background: rgba(242,113,33,0.12);
            border: 1px solid rgba(242,113,33,0.22);
            color: rgba(17,24,39,0.85);
            font-weight: 900;
            font-size: 0.9rem;
        }

        .solar-kpi {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
            background: linear-gradient(135deg, rgba(102,126,234,0.12), rgba(242,113,33,0.10));
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 14px;
            padding: 12px 12px;
        }

        .solar-kpi .value {
            font-weight: 950;
            font-size: 1.35rem;
            color: #111827;
            letter-spacing: 0.2px;
        }

        .solar-kpi .unit {
            font-weight: 900;
            color: rgba(17,24,39,0.72);
        }

        .chart-frame {
            width: 100%;
            height: 240px;
            background: radial-gradient(circle at 20% 10%, rgba(102,126,234,0.10), transparent 55%),
                        radial-gradient(circle at 80% 0%, rgba(242,113,33,0.10), transparent 55%),
                        #fff;
            border-radius: 16px;
            padding: 12px;
            box-sizing: border-box;
            border: 1px solid rgba(0,0,0,0.06);
        }
    </style>
}

<div class="container">

    <div class="uv-card">
        <div class="uv-header">
            <h2>
                <i class="fas fa-chart-line"></i> @L["Live_Title"]
                <span class="live-dot"></span>
            </h2>

            <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; justify-content:flex-end;">
                <div class="location-info">
                    <i class="fas fa-map-marker-alt"></i>
                    <span id="location">@location</span>
                </div>

                <button id="refreshLocationBtn" type="button" class="buy-btn" style="margin-top:0;">
                    <i class="fas fa-location-crosshairs"></i> Refresh location
                </button>
                <button id="generateReadingBtn" type="button" class="cancel-btn" style="margin-top:0;">
                    <i class="fas fa-rotate"></i> Refresh UV
                </button>
            </div>
        </div>

        <div class="uv-content">

            <!-- LEFT -->
            <div class="uv-value-container">
                <div class="uv-value" id="uvValue">@currentUv.ToString("0.0")</div>
                <div class="uv-label">@L["Live_UvIndexLabel"]</div>

                <div style="margin-top:10px;">
                    <span class="pill-badge" title="Solar estimate from UV Index">
                        <i class="fas fa-solar-panel" style="color:#F27121;"></i>
                        <span id="solarKwhInline">Solar: — kWh</span>
                    </span>
                </div>

                <div id="safetyMessage" class="safety-badge" style="background:@(rec?.ColorCode ?? "#2ecc71");">
                    <i class="fas @(string.IsNullOrWhiteSpace(rec?.Icon) ? "fa-smile" : rec!.Icon)"></i>
                    <span id="safetyStatusText">@(rec?.Status ?? L["Live_LowRisk"].Value)</span>
                </div>
            </div>

            <!-- RIGHT -->
            <div>
                <div id="recommendationText" class="recommendation-text">
                    @(rec?.Message ?? L["Live_RecommendationDefault"].Value)
                </div>

                <div class="protection-box">
                    <i class="fas fa-shield-alt"></i>
                    <strong>@L["Live_Protection"]</strong>
                    <span id="protectionAdvice">@(rec?.Protection ?? L["Live_NoProtection"].Value)</span>
                </div>

                <div class="timestamp">
                    <i class="far fa-clock"></i>
                    @L["Live_LastReading"] <span id="timestamp">@timestamp</span>
                </div>

                <div class="data-source">
                    <i class="fas fa-microchip"></i>
                    @L["Live_DataSource"]
                </div>

                <div id="liveUvStatus" style="margin-top:0.75rem; font-size:0.9rem; color:#666;"></div>
            </div>

        </div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">

        <div class="stat-card">
            <i class="fas fa-chart-line"></i>
            <div class="stat-value" id="avgUv">@avgUv.ToString("0.0")</div>
            <div class="stat-label">@L["Live_AverageUvToday"]</div>
        </div>

        <div class="stat-card">
            <i class="fas fa-chart-bar"></i>
            <div class="stat-value" id="peakUv">@peakUv.ToString("0.0")</div>
            <div class="stat-label">@L["Live_PeakUvToday"]</div>
            <div class="stat-time" id="peakTime">@peakTime</div>
        </div>

        <div class="stat-card">
            <i class="fas fa-database"></i>
            <div class="stat-value" id="readingsCount">@readingsCount</div>
            <div class="stat-label">@L["Live_ReadingsToday"]</div>
        </div>

        <div class="stat-card">
            <i class="fas fa-thermometer-half"></i>
            <div class="stat-value" id="currentUv">@currentUv.ToString("0.0")</div>
            <div class="stat-label">@L["Live_CurrentUvIndex"]</div>
        </div>

    </div>

    <div class="uv-card" style="padding:1.5rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.75rem;">
            <h3 style="margin:0; display:flex; align-items:center; gap:0.5rem;">
                <i class="fas fa-chart-area" style="color:#F27121;"></i>
                UV readings (last 24h)
            </h3>
            <div style="font-size:0.85rem; color:#666;">
                Y: UV index, X: time
            </div>
        </div>

        <div id="uvChartWrap" style="width:100%; height:260px; background:white; border-radius:14px; padding:12px; box-sizing:border-box;">
            <svg id="uvChart" viewBox="0 0 800 260" preserveAspectRatio="none" style="width:100%; height:100%; display:block;">
                <defs>
                    <linearGradient id="uvLineGrad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#F9A826" />
                        <stop offset="100%" stop-color="#F27121" />
                    </linearGradient>
                    <linearGradient id="uvAreaGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#F27121" stop-opacity="0.22" />
                        <stop offset="100%" stop-color="#F27121" stop-opacity="0.00" />
                    </linearGradient>
                    <filter id="uvLineShadow" x="-20%" y="-40%" width="140%" height="200%">
                        <feDropShadow dx="0" dy="2" stdDeviation="2.2" flood-color="#F27121" flood-opacity="0.25" />
                    </filter>
                </defs>
                <rect x="0" y="0" width="800" height="260" fill="transparent"></rect>
                <g id="uvChartGrid"></g>
                <path id="uvChartArea" d="" fill="url(#uvAreaGrad)"></path>
                <path id="uvChartLine" d="" fill="none" stroke="url(#uvLineGrad)" stroke-width="3.25" stroke-linejoin="round" stroke-linecap="round" filter="url(#uvLineShadow)"></path>
                <g id="uvChartDots"></g>
                <g id="uvChartYLabels"></g>
                <g id="uvChartXLabels"></g>
            </svg>
        </div>
        <div id="uvChartHint" style="margin-top:0.5rem; font-size:0.85rem; color:#777;"></div>
    </div>

    <div class="uv-card solar-shell" style="padding:1.5rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.75rem;">
            <h3 style="margin:0; display:flex; align-items:center; gap:0.5rem;">
                <i class="fas fa-solar-panel" style="color:#F27121;"></i>
                Solar energy estimate (kWh)
            </h3>
            <div style="font-size:0.85rem; color:#666;">
                E = A × (1.6 / UV) × η × t
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="solar-card">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div>
                            <div style="font-weight:950;">Calculator</div>
                            <div class="help-muted">
                                Fill <strong>t</strong> (hours) and <strong>η</strong> (efficiency).
                                Reminder: efficiency is typically <strong>15%–22%</strong>.
                            </div>
                        </div>
                        <div style="text-align:right;">
                            <div class="help-muted">Using current UV</div>
                            <div style="font-weight:950; font-size:1.05rem;">
                                <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">
                                    UV <span id="solarUvUsed">—</span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight:900;">t (hours)</label>
                            <div class="input-group">
                                <input id="solarHours" class="form-control" type="number" min="0" step="0.25" placeholder="e.g. 4">
                                <span class="input-group-text">h</span>
                            </div>
                            <div class="invalid-feedback">Please enter time in hours (t).</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight:900;">η (efficiency)</label>
                            <div class="input-group">
                                <input id="solarEta" class="form-control" type="number" min="0" step="0.01" placeholder="e.g. 0.18 or 18">
                                <span class="input-group-text">%</span>
                            </div>
                            <div class="invalid-feedback">Please enter efficiency (η) between 0.15 and 0.22 (15%–22%).</div>
                            <div class="help-muted mt-1">Accepts <strong>0.15–0.22</strong> or <strong>15–22</strong>.</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" style="font-weight:900;">A (panel area, m²)</label>
                            <div class="input-group">
                                <input id="solarArea" class="form-control" type="number" value="1" min="0" step="0.1" placeholder="e.g. 1.6">
                                <span class="input-group-text">m²</span>
                            </div>
                            <div class="invalid-feedback">Please enter panel area (A) in m².</div>
                        </div>
                        <div class="col-12 col-md-6 d-flex align-items-end">
                            <button id="solarCalcBtn" type="button" class="btn btn-primary" style="margin-top:0; width:100%; border-radius:12px; font-weight:900;">
                                <i class="fas fa-bolt"></i> Calculate kWh
                            </button>
                        </div>
                    </div>

                    <div class="mt-3 solar-kpi">
                        <div>
                            <div style="font-weight:950;">Estimated energy</div>
                            <div id="solarStatus" class="help-muted mt-1"></div>
                        </div>
                        <div style="text-align:right;">
                            <div class="value"><span id="solarKwh">—</span></div>
                            <div class="unit">kWh</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="solar-card">
                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-2">
                        <div style="font-weight:950;">Diagram</div>
                        <div class="help-muted">Y: kWh, X: hours</div>
                    </div>
                    <div class="chart-frame">
                        <svg id="solarChart" viewBox="0 0 800 240" preserveAspectRatio="none" style="width:100%; height:100%; display:block;">
                            <defs>
                                <linearGradient id="solarLineGrad" x1="0" y1="0" x2="1" y2="0">
                                    <stop offset="0%" stop-color="#667eea" />
                                    <stop offset="100%" stop-color="#F27121" />
                                </linearGradient>
                                <linearGradient id="solarAreaGrad" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#667eea" stop-opacity="0.20" />
                                    <stop offset="100%" stop-color="#667eea" stop-opacity="0.00" />
                                </linearGradient>
                            </defs>
                            <rect x="0" y="0" width="800" height="240" fill="transparent"></rect>
                            <g id="solarGrid"></g>
                            <path id="solarAreaPath" d="" fill="url(#solarAreaGrad)"></path>
                            <path id="solarLinePath" d="" fill="none" stroke="url(#solarLineGrad)" stroke-width="3.0" stroke-linecap="round" stroke-linejoin="round"></path>
                            <g id="solarLabels"></g>
                            <g id="solarOverlay"></g>
                        </svg>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-2" style="align-items:center;">
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">UV <span id="solarDiagUv">—</span></span>
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">A <span id="solarDiagA">—</span> m²</span>
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">η <span id="solarDiagEta">—</span></span>
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">t <span id="solarDiagT">—</span> h</span>
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08);">kWh/h <span id="solarDiagPerHour">—</span></span>
                        <span class="badge text-bg-light" style="border:1px solid rgba(0,0,0,0.08); font-weight:950;">E <span id="solarDiagE">—</span> kWh</span>
                    </div>
                    <div id="solarEquation" class="help-muted mt-2" style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;"></div>
                    <div id="solarHint" class="help-muted mt-2"></div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const els = {
            location: document.getElementById('location'),
            uvValue: document.getElementById('uvValue'),
            safetyMessage: document.getElementById('safetyMessage'),
            safetyStatusText: document.getElementById('safetyStatusText'),
            recommendationText: document.getElementById('recommendationText'),
            protectionAdvice: document.getElementById('protectionAdvice'),
            timestamp: document.getElementById('timestamp'),
            avgUv: document.getElementById('avgUv'),
            peakUv: document.getElementById('peakUv'),
            peakTime: document.getElementById('peakTime'),
            readingsCount: document.getElementById('readingsCount'),
            currentUv: document.getElementById('currentUv'),
            status: document.getElementById('liveUvStatus'),
            refreshBtn: document.getElementById('refreshLocationBtn'),
            generateBtn: document.getElementById('generateReadingBtn'),
        };

        function pick(obj, keys) {
            if (!obj) return undefined;
            for (const k of keys) {
                if (obj[k] !== undefined && obj[k] !== null) return obj[k];
            }
            return undefined;
        }

        function setStatus(text) {
            if (!els.status) return;
            els.status.textContent = text || '';
        }

        function setButtonsLoading(isLoading) {
            if (els.refreshBtn) els.refreshBtn.disabled = isLoading;
            if (els.generateBtn) els.generateBtn.disabled = isLoading;
        }

        const chart = {
            svg: document.getElementById('uvChart'),
            grid: document.getElementById('uvChartGrid'),
            line: document.getElementById('uvChartLine'),
            area: document.getElementById('uvChartArea'),
            dots: document.getElementById('uvChartDots'),
            yLabels: document.getElementById('uvChartYLabels'),
            xLabels: document.getElementById('uvChartXLabels'),
            hint: document.getElementById('uvChartHint')
        };

        function clearChart() {
            if (chart.grid) chart.grid.innerHTML = '';
            if (chart.dots) chart.dots.innerHTML = '';
            if (chart.yLabels) chart.yLabels.innerHTML = '';
            if (chart.xLabels) chart.xLabels.innerHTML = '';
            if (chart.line) chart.line.setAttribute('d', '');
            if (chart.area) chart.area.setAttribute('d', '');
        }

        function fmtTimeHHmm(d) {
            try {
                return new Intl.DateTimeFormat(undefined, { hour: '2-digit', minute: '2-digit', hour12: false }).format(d);
            } catch {
                const hh = String(d.getHours()).padStart(2, '0');
                const mm = String(d.getMinutes()).padStart(2, '0');
                return `${hh}:${mm}`;
            }
        }

        function buildSmoothPath(coords) {
            // coords: [{x,y}]
            if (!coords || coords.length < 2) return '';
            if (coords.length === 2) {
                return `M ${coords[0].x.toFixed(1)} ${coords[0].y.toFixed(1)} L ${coords[1].x.toFixed(1)} ${coords[1].y.toFixed(1)}`;
            }

            let d = `M ${coords[0].x.toFixed(1)} ${coords[0].y.toFixed(1)}`;
            for (let i = 1; i < coords.length - 1; i++) {
                const midX = (coords[i].x + coords[i + 1].x) / 2;
                const midY = (coords[i].y + coords[i + 1].y) / 2;
                d += ` Q ${coords[i].x.toFixed(1)} ${coords[i].y.toFixed(1)} ${midX.toFixed(1)} ${midY.toFixed(1)}`;
            }
            const last = coords[coords.length - 1];
            d += ` T ${last.x.toFixed(1)} ${last.y.toFixed(1)}`;
            return d;
        }

        function drawChart(points) {
            // points: [{ ts: Date, value: number, label: string }]
            if (!chart.svg || !chart.line || !chart.grid || !chart.dots || !chart.yLabels || !chart.xLabels || !chart.area) return;
            clearChart();

            if (!Array.isArray(points) || points.length < 2) {
                if (chart.hint) chart.hint.textContent = 'Not enough data yet. Refresh UV a few times to build a history.';
                return;
            }
            if (chart.hint) chart.hint.textContent = `${points.length} readings plotted.`;

            const W = 800, H = 260;
            const pad = { l: 44, r: 16, t: 12, b: 32 };

            const minTs = Math.min(...points.map(p => p.ts.getTime()));
            const maxTs = Math.max(...points.map(p => p.ts.getTime()));
            const minV = 0;
            const maxV = Math.max(1, Math.ceil(Math.max(...points.map(p => p.value)) + 0.5));

            const x = (ts) => {
                if (maxTs === minTs) return pad.l;
                return pad.l + ((ts - minTs) / (maxTs - minTs)) * (W - pad.l - pad.r);
            };
            const y = (v) => {
                const vv = Math.max(minV, Math.min(maxV, v));
                return pad.t + (1 - (vv - minV) / (maxV - minV)) * (H - pad.t - pad.b);
            };

            // Grid + Y labels
            const yTicks = 4;
            for (let i = 0; i <= yTicks; i++) {
                const v = minV + (i / yTicks) * (maxV - minV);
                const yy = y(v);
                chart.grid.insertAdjacentHTML('beforeend',
                    `<line x1="${pad.l}" y1="${yy}" x2="${W - pad.r}" y2="${yy}" stroke="rgba(17,24,39,${i === 0 ? 0.10 : 0.06})" stroke-width="1" />`
                );
                chart.yLabels.insertAdjacentHTML('beforeend',
                    `<text x="${pad.l - 10}" y="${yy + 4}" text-anchor="end" font-size="11" font-weight="800" fill="rgba(17,24,39,0.62)">${v.toFixed(0)}</text>`
                );
            }

            // X labels (designed pills, up to 6)
            const xTicks = Math.min(6, points.length);
            for (let i = 0; i < xTicks; i++) {
                const idx = Math.round((i / (xTicks - 1)) * (points.length - 1));
                const p = points[idx];
                const xx = x(p.ts.getTime());

                // vertical grid at tick
                chart.grid.insertAdjacentHTML('beforeend',
                    `<line x1="${xx}" y1="${pad.t}" x2="${xx}" y2="${H - pad.b}" stroke="rgba(17,24,39,0.04)" stroke-width="1" />`
                );

                // bottom tick mark
                chart.grid.insertAdjacentHTML('beforeend',
                    `<line x1="${xx}" y1="${H - pad.b + 1}" x2="${xx}" y2="${H - pad.b + 7}" stroke="rgba(17,24,39,0.18)" stroke-width="1" />`
                );

                const label = fmtTimeHHmm(p.ts);
                const pillW = 54;
                const pillH = 18;
                const pillX = Math.max(pad.l, Math.min(W - pad.r - pillW, xx - pillW / 2));
                const pillY = H - 24;
                const textX = pillX + pillW / 2;
                const textY = pillY + 13;

                chart.xLabels.insertAdjacentHTML('beforeend',
                    `<g>
                        <rect x="${pillX}" y="${pillY}" width="${pillW}" height="${pillH}" rx="9"
                              fill="rgba(244,245,247,0.92)" stroke="rgba(17,24,39,0.10)" />
                        <text x="${textX}" y="${textY}" text-anchor="middle"
                              font-size="11" font-weight="900" fill="rgba(17,24,39,0.78)">${label}</text>
                    </g>`
                );
            }

            const coords = points.map(p => ({ x: x(p.ts.getTime()), y: y(p.value) }));
            const dLine = buildSmoothPath(coords);
            chart.line.setAttribute('d', dLine);

            const baseY = y(minV);
            const first = coords[0];
            const lastCoord = coords[coords.length - 1];
            const dArea = `${dLine} L ${lastCoord.x.toFixed(1)} ${baseY.toFixed(1)} L ${first.x.toFixed(1)} ${baseY.toFixed(1)} Z`;
            chart.area.setAttribute('d', dArea);

            // Dots
            const lastPoint = points[points.length - 1];
            for (const p of points) {
                const cx = x(p.ts.getTime());
                const cy = y(p.value);
                const isLast = p === lastPoint;
                chart.dots.insertAdjacentHTML('beforeend',
                    isLast
                        ? `<g>
                               <circle cx="${cx}" cy="${cy}" r="7.2" fill="rgba(242,113,33,0.14)" />
                               <circle cx="${cx}" cy="${cy}" r="4.2" fill="#F27121" />
                           </g>`
                        : `<circle cx="${cx}" cy="${cy}" r="2.8" fill="rgba(242,113,33,0.60)" />`
                );
            }
        }

        async function refreshHistoryChart() {
            try {
                const res = await fetch('/LiveUV/GetHistory', { headers: { 'Accept': 'application/json' } });
                const data = await res.json().catch(() => null);
                if (!res.ok || !Array.isArray(data)) return;

                const points = data
                    .map(d => {
                        const v = pick(d, ['value', 'Value']);
                        const tsRaw = pick(d, ['timestamp', 'Timestamp']);
                        const ts = tsRaw ? new Date(tsRaw) : null;
                        if (typeof v !== 'number' || !ts || Number.isNaN(ts.getTime())) return null;
                        return { value: v, ts, label: fmtTimeHHmm(ts) };
                    })
                    .filter(Boolean);

                drawChart(points);
            } catch {
                // ignore
            }
        }

        // ---- Solar calculator ----
        const solarEls = {
            hours: document.getElementById('solarHours'),
            eta: document.getElementById('solarEta'),
            btn: document.getElementById('solarCalcBtn'),
            areaInput: document.getElementById('solarArea'),
            kwh: document.getElementById('solarKwh'),
            inline: document.getElementById('solarKwhInline'),
            status: document.getElementById('solarStatus'),
            uvUsed: document.getElementById('solarUvUsed'),
            chart: document.getElementById('solarChart'),
            grid: document.getElementById('solarGrid'),
            labels: document.getElementById('solarLabels'),
            line: document.getElementById('solarLinePath'),
            areaPath: document.getElementById('solarAreaPath'),
            hint: document.getElementById('solarHint'),
            diagUv: document.getElementById('solarDiagUv'),
            diagA: document.getElementById('solarDiagA'),
            diagEta: document.getElementById('solarDiagEta'),
            diagT: document.getElementById('solarDiagT'),
            diagPerHour: document.getElementById('solarDiagPerHour'),
            diagE: document.getElementById('solarDiagE'),
            equation: document.getElementById('solarEquation'),
            overlay: document.getElementById('solarOverlay')
        };

        function clamp(n, a, b) { return Math.max(a, Math.min(b, n)); }

        function parseNum(raw) {
            if (raw == null) return null;
            const s = String(raw).trim().replace(',', '.');
            if (!s) return null;
            const v = Number.parseFloat(s);
            return Number.isFinite(v) ? v : null;
        }

        function parseEta(raw) {
            let v = parseNum(raw);
            if (v == null) return null;
            if (v > 1) v = v / 100.0; // percent input
            return v;
        }

        function setInvalid(el, isInvalid) {
            if (!el) return;
            el.classList.toggle('is-invalid', !!isInvalid);
        }

        function solarClearChart() {
            if (solarEls.grid) solarEls.grid.innerHTML = '';
            if (solarEls.labels) solarEls.labels.innerHTML = '';
            if (solarEls.line) solarEls.line.setAttribute('d', '');
            if (solarEls.areaPath) solarEls.areaPath.setAttribute('d', '');
            if (solarEls.overlay) solarEls.overlay.innerHTML = '';
        }

        function escXml(s) {
            return String(s)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function solarSetOverlay(lines) {
            if (!solarEls.overlay) return;
            const safe = (lines || []).map(escXml);
            const pad = { x: 14, y: 14 };
            const lineH = 16;
            const fontSize = 12;
            const w = 360;
            const h = 12 + safe.length * lineH;
            let y = pad.y + 20;

            let html = `
                <rect x="${pad.x}" y="${pad.y}" rx="12" ry="12" width="${w}" height="${h}"
                      fill="rgba(255,255,255,0.78)" stroke="rgba(17,24,39,0.10)" />
                <text x="${pad.x + 14}" y="${pad.y + 22}" font-size="${fontSize}" font-weight="900"
                      fill="rgba(17,24,39,0.90)">Calculation</text>
            `;
            for (let i = 0; i < safe.length; i++) {
                html += `<text x="${pad.x + 14}" y="${y + i * lineH}" font-size="${fontSize}" font-weight="700" fill="rgba(17,24,39,0.78)">${safe[i]}</text>`;
            }
            solarEls.overlay.innerHTML = html;
        }

        function solarDrawChart(tHours, perHourKwh) {
            if (!solarEls.chart || !solarEls.grid || !solarEls.labels || !solarEls.line || !solarEls.areaPath) return;
            solarClearChart();

            const W = 800, H = 240;
            const pad = { l: 44, r: 16, t: 12, b: 32 };

            const maxX = Math.max(1, tHours);
            const maxY = Math.max(0.001, perHourKwh * maxX);

            const x = (hh) => pad.l + (hh / maxX) * (W - pad.l - pad.r);
            const y = (kwh) => pad.t + (1 - (kwh / maxY)) * (H - pad.t - pad.b);

            // grid + y labels
            const yTicks = 4;
            for (let i = 0; i <= yTicks; i++) {
                const v = (i / yTicks) * maxY;
                const yy = y(v);
                solarEls.grid.insertAdjacentHTML('beforeend',
                    `<line x1="${pad.l}" y1="${yy}" x2="${W - pad.r}" y2="${yy}" stroke="rgba(17,24,39,${i===0?0.10:0.06})" stroke-width="1" />`
                );
                solarEls.labels.insertAdjacentHTML('beforeend',
                    `<text x="${pad.l - 10}" y="${yy + 4}" text-anchor="end" font-size="11" font-weight="800" fill="rgba(17,24,39,0.62)">${v.toFixed(2)}</text>`
                );
            }

            // x labels at 0, mid, end
            const xTicks = 3;
            for (let i = 0; i < xTicks; i++) {
                const hh = (i / (xTicks - 1)) * maxX;
                const xx = x(hh);
                solarEls.grid.insertAdjacentHTML('beforeend',
                    `<line x1="${xx}" y1="${pad.t}" x2="${xx}" y2="${H - pad.b}" stroke="rgba(17,24,39,0.04)" stroke-width="1" />`
                );
                solarEls.labels.insertAdjacentHTML('beforeend',
                    `<text x="${xx}" y="${H - 10}" text-anchor="middle" font-size="11" font-weight="900" fill="rgba(17,24,39,0.78)">${hh.toFixed(0)}h</text>`
                );
            }

            // line (cumulative energy)
            const steps = Math.max(2, Math.min(60, Math.ceil(maxX * 6))); // up to 10-min resolution
            const coords = [];
            for (let i = 0; i <= steps; i++) {
                const hh = (i / steps) * maxX;
                const e = perHourKwh * hh;
                coords.push({ x: x(hh), y: y(e) });
            }

            let d = `M ${coords[0].x.toFixed(1)} ${coords[0].y.toFixed(1)}`;
            for (let i = 1; i < coords.length; i++) {
                d += ` L ${coords[i].x.toFixed(1)} ${coords[i].y.toFixed(1)}`;
            }
            solarEls.line.setAttribute('d', d);

            const baseY = y(0);
            const dArea = `${d} L ${coords[coords.length - 1].x.toFixed(1)} ${baseY.toFixed(1)} L ${coords[0].x.toFixed(1)} ${baseY.toFixed(1)} Z`;
            solarEls.areaPath.setAttribute('d', dArea);
        }

        function solarRecalc() {
            if (!solarEls.hours || !solarEls.eta || !solarEls.areaInput || !solarEls.kwh || !solarEls.inline || !solarEls.status || !solarEls.uvUsed) return;

            const uv = Number((els.uvValue && els.uvValue.textContent) ? els.uvValue.textContent : '0');
            solarEls.uvUsed.textContent = Number.isFinite(uv) ? uv.toFixed(1) : '—';

            const t = parseNum(solarEls.hours.value);
            const eta = parseEta(solarEls.eta.value);
            const A = parseNum(solarEls.areaInput.value);

            const badT = !(t != null && t > 0);
            const badEta = !(eta != null && eta > 0);
            const badA = !(A != null && A > 0);
            setInvalid(solarEls.hours, badT);
            setInvalid(solarEls.eta, badEta);
            setInvalid(solarEls.areaInput, badA);

            if (badT || badEta || badA) {
                const missing = [];
                if (badA) missing.push('A');
                if (badT) missing.push('t');
                if (badEta) missing.push('η');
                solarEls.status.textContent = `Please fill ${missing.join(', ')} to calculate.`;
                solarEls.kwh.textContent = '—';
                solarEls.inline.textContent = 'Solar: — kWh';
                if (solarEls.hint) solarEls.hint.textContent = 'Enter A (m²), t (hours), and η, then press Calculate.';
                if (solarEls.diagUv) solarEls.diagUv.textContent = Number.isFinite(uv) ? uv.toFixed(1) : '—';
                if (solarEls.diagA) solarEls.diagA.textContent = (A != null && A > 0) ? A.toFixed(2) : '—';
                if (solarEls.diagEta) solarEls.diagEta.textContent = (eta != null && eta > 0) ? eta.toFixed(3) : '—';
                if (solarEls.diagT) solarEls.diagT.textContent = (t != null && t > 0) ? t.toFixed(2) : '—';
                if (solarEls.diagPerHour) solarEls.diagPerHour.textContent = '—';
                if (solarEls.diagE) solarEls.diagE.textContent = '—';
                if (solarEls.equation) {
                    solarEls.equation.innerHTML =
                        `<div>E = A × (1.6 / UV) × η × t</div>
                         <div class="help-muted">Fill missing values to show the full calculation steps.</div>`;
                }
                solarSetOverlay([
                    'E = A × (1.6/UV) × η × t',
                    `UV = ${Number.isFinite(uv) ? uv.toFixed(1) : '—'}`,
                    `A = ${(A != null && A > 0) ? A.toFixed(2) : '—'} m²`,
                    `η = ${(eta != null && eta > 0) ? eta.toFixed(3) : '—'}`,
                    `t = ${(t != null && t > 0) ? t.toFixed(2) : '—'} h`,
                    'Fill missing values to calculate.'
                ]);
                solarClearChart();
                return;
            }

            if (!Number.isFinite(uv) || uv <= 0) {
                // Avoid "doesn't work" feel when UV is 0 (night time / no data yet).
                // We treat UV<=0 as 0 production for this estimate.
                const perHourZero = 0;
                const E0 = 0;
                solarEls.kwh.textContent = E0.toFixed(3);
                solarEls.inline.textContent = `Solar: ${E0.toFixed(2)} kWh`;
                solarEls.status.textContent = `UV is 0.0 → estimated production is 0 kWh. (A=${A.toFixed(2)}m², η=${eta.toFixed(2)}, t=${t.toFixed(2)}h)`;
                if (solarEls.hint) solarEls.hint.textContent = 'UV is 0, so the diagram is flat at 0 kWh.';
                if (solarEls.diagUv) solarEls.diagUv.textContent = '0.0';
                if (solarEls.diagA) solarEls.diagA.textContent = A.toFixed(2);
                if (solarEls.diagEta) solarEls.diagEta.textContent = eta.toFixed(3);
                if (solarEls.diagT) solarEls.diagT.textContent = t.toFixed(2);
                if (solarEls.diagPerHour) solarEls.diagPerHour.textContent = perHourZero.toFixed(3);
                if (solarEls.diagE) solarEls.diagE.textContent = E0.toFixed(3);
                if (solarEls.equation) {
                    const etaPct = (eta * 100);
                    solarEls.equation.innerHTML =
                        `<div>E = A × (1.6 / UV) × η × t</div>
                         <div>UV ≤ 0 ⇒ E = 0 kWh</div>
                         <div>A = ${A.toFixed(2)} m²</div>
                         <div>η = ${eta.toFixed(3)} (${etaPct.toFixed(1)}%)</div>
                         <div>t = ${t.toFixed(2)} h</div>`;
                }
                solarSetOverlay([
                    'E = A × (1.6/UV) × η × t',
                    `UV = 0.0 → E = 0.0000 kWh`,
                    `A = ${A.toFixed(2)} m²`,
                    `η = ${eta.toFixed(3)} (${(eta * 100).toFixed(1)}%)`,
                    `t = ${t.toFixed(2)} h`
                ]);
                solarDrawChart(t, perHourZero);
                return;
            }

            const factor = 1.6 / uv;
            const aScaled = A * factor;
            const perHour = aScaled * eta; // kWh per hour
            const E = perHour * t;

            solarEls.kwh.textContent = E.toFixed(3);
            solarEls.inline.textContent = `Solar: ${E.toFixed(2)} kWh`;
            solarEls.status.textContent = `Using A=${A.toFixed(2)}m², UV=${uv.toFixed(1)}, η=${eta.toFixed(2)}, t=${t.toFixed(2)}h`;
            if (solarEls.hint) solarEls.hint.textContent = 'Cumulative kWh over time.';
            if (solarEls.diagUv) solarEls.diagUv.textContent = uv.toFixed(1);
            if (solarEls.diagA) solarEls.diagA.textContent = A.toFixed(2);
            if (solarEls.diagEta) solarEls.diagEta.textContent = eta.toFixed(3);
            if (solarEls.diagT) solarEls.diagT.textContent = t.toFixed(2);
            if (solarEls.diagPerHour) solarEls.diagPerHour.textContent = perHour.toFixed(3);
            if (solarEls.diagE) solarEls.diagE.textContent = E.toFixed(3);
            if (solarEls.equation) {
                const etaPct = (eta * 100);
                solarEls.equation.innerHTML =
                    `<div>E = A × (1.6 / UV) × η × t</div>
                     <div>1.6 / UV = 1.6 / ${uv.toFixed(1)} = ${factor.toFixed(4)}</div>
                     <div>A × (1.6 / UV) = ${A.toFixed(2)} × ${factor.toFixed(4)} = ${aScaled.toFixed(4)}</div>
                     <div>kWh/h = ${aScaled.toFixed(4)} × η = ${aScaled.toFixed(4)} × ${eta.toFixed(3)} (${etaPct.toFixed(1)}%) = ${perHour.toFixed(4)}</div>
                     <div>E = (kWh/h) × t = ${perHour.toFixed(4)} × ${t.toFixed(2)} = <strong>${E.toFixed(4)} kWh</strong></div>`;
            }
            solarSetOverlay([
                'E = A × (1.6/UV) × η × t',
                `UV = ${uv.toFixed(1)}`,
                `1.6/UV = 1.6/${uv.toFixed(1)} = ${factor.toFixed(6)}`,
                `A = ${A.toFixed(2)} m²`,
                `A×(1.6/UV) = ${A.toFixed(2)}×${factor.toFixed(6)} = ${aScaled.toFixed(6)}`,
                `η = ${eta.toFixed(3)} (${(eta * 100).toFixed(1)}%)`,
                `kWh/h = ${aScaled.toFixed(6)}×${eta.toFixed(3)} = ${perHour.toFixed(6)}`,
                `t = ${t.toFixed(2)} h`,
                `E = ${perHour.toFixed(6)}×${t.toFixed(2)} = ${E.toFixed(6)} kWh`
            ]);
            solarDrawChart(t, perHour);
        }

        if (solarEls.btn) solarEls.btn.addEventListener('click', solarRecalc);
        if (solarEls.hours) solarEls.hours.addEventListener('input', () => {
            setInvalid(solarEls.hours, false);
            if (solarEls.hours.value || solarEls.eta?.value || solarEls.areaInput?.value) solarRecalc();
        });
        if (solarEls.eta) solarEls.eta.addEventListener('input', () => {
            setInvalid(solarEls.eta, false);
            if (solarEls.hours?.value || solarEls.eta.value || solarEls.areaInput?.value) solarRecalc();
        });
        if (solarEls.areaInput) solarEls.areaInput.addEventListener('input', () => {
            setInvalid(solarEls.areaInput, false);
            if (solarEls.hours?.value || solarEls.eta?.value || solarEls.areaInput.value) solarRecalc();
        });

        function renderPayload(payload) {
            const reading = payload && payload.reading;
            const rec = payload && payload.recommendation;
            const stats = payload && payload.statistics;

            if (reading) {
                const loc = pick(reading, ['location', 'Location']);
                const ts = pick(reading, ['timestamp', 'Timestamp']);
                if (typeof loc === 'string' && els.location) els.location.textContent = loc;
                if (typeof ts === 'string' && els.timestamp) els.timestamp.textContent = ts;
            }

            const uv = (stats && typeof pick(stats, ['currentUV', 'CurrentUV']) === 'number') ? pick(stats, ['currentUV', 'CurrentUV'])
                : (reading && typeof pick(reading, ['value', 'Value']) === 'number') ? pick(reading, ['value', 'Value'])
                : null;

            if (uv != null) {
                const formatted = uv.toFixed(1);
                if (els.uvValue) els.uvValue.textContent = formatted;
                if (els.currentUv) els.currentUv.textContent = formatted;
                // if user already filled calculator, keep it in sync with UV changes
                if (solarEls && solarEls.hours && solarEls.eta && (solarEls.hours.value || solarEls.eta.value)) {
                    solarRecalc();
                }
            }

            if (rec) {
                const msg = pick(rec, ['message', 'Message']);
                const prot = pick(rec, ['protection', 'Protection']);
                const status = pick(rec, ['status', 'Status']);
                const color = pick(rec, ['colorCode', 'ColorCode']);
                const icon = pick(rec, ['icon', 'Icon']);

                if (typeof msg === 'string' && els.recommendationText) els.recommendationText.textContent = msg;
                if (typeof prot === 'string' && els.protectionAdvice) els.protectionAdvice.textContent = prot;
                if (typeof status === 'string' && els.safetyStatusText) els.safetyStatusText.textContent = status;
                if (typeof color === 'string' && els.safetyMessage) els.safetyMessage.style.background = color;

                if (els.safetyMessage) {
                    const iconEl = els.safetyMessage.querySelector('i');
                    if (iconEl) {
                        const cls = (typeof icon === 'string' && icon.trim()) ? icon.trim() : 'fa-smile';
                        iconEl.className = `fas ${cls}`;
                    }
                }
            }

            if (stats) {
                const avg = pick(stats, ['averageUV', 'AverageUV']);
                const max = pick(stats, ['maxUVToday', 'MaxUVToday']);
                const pt = pick(stats, ['peakTime', 'PeakTime']);
                const count = pick(stats, ['readingsCount', 'ReadingsCount']);

                if (typeof avg === 'number' && els.avgUv) els.avgUv.textContent = avg.toFixed(1);
                if (typeof max === 'number' && els.peakUv) els.peakUv.textContent = max.toFixed(1);
                if (typeof pt === 'string' && els.peakTime) els.peakTime.textContent = pt;
                if (typeof count === 'number' && els.readingsCount) els.readingsCount.textContent = String(count);
            }
        }

        async function refreshByCoords(lat, lng) {
            setButtonsLoading(true);
            setStatus('Updating from your location…');
            try {
                const res = await fetch('/LiveUV/GetUVByLocation', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                    body: JSON.stringify({ lat, lng })
                });
                const data = await res.json().catch(() => null);
                if (!res.ok || !data || !data.success) {
                    setStatus((data && data.message) ? data.message : 'Could not refresh UV data.');
                    return;
                }
                renderPayload(data);
                refreshHistoryChart();
                setStatus('Updated.');
            } catch {
                setStatus('Could not refresh UV data.');
            } finally {
                setButtonsLoading(false);
                setTimeout(() => setStatus(''), 2500);
            }
        }

        function getStoredCoords() {
            try {
                const raw = localStorage.getItem('liveuv_last_coords');
                if (!raw) return null;
                const parsed = JSON.parse(raw);
                const lat = parsed && typeof parsed.lat === 'number' ? parsed.lat : null;
                const lng = parsed && typeof parsed.lng === 'number' ? parsed.lng : null;
                if (lat == null || lng == null) return null;
                return { lat, lng };
            } catch {
                return null;
            }
        }

        function storeCoords(lat, lng) {
            try {
                localStorage.setItem('liveuv_last_coords', JSON.stringify({ lat, lng, at: Date.now() }));
            } catch { }
        }

        function refreshUsingBrowserLocation() {
            if (!navigator.geolocation) {
                setStatus('Geolocation is not supported in this browser.');
                return;
            }

            setButtonsLoading(true);
            setStatus('Requesting location permission…');
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    const lat = pos.coords.latitude;
                    const lng = pos.coords.longitude;
                    storeCoords(lat, lng);
                    refreshByCoords(lat, lng);
                },
                () => {
                    setButtonsLoading(false);
                    setStatus('Location permission denied.');
                    setTimeout(() => setStatus(''), 2500);
                },
                { enableHighAccuracy: true, timeout: 8000, maximumAge: 30000 }
            );
        }

        function refreshUsingStoredOrBrowserLocation() {
            const stored = getStoredCoords();
            if (stored) {
                refreshByCoords(stored.lat, stored.lng);
                return;
            }
            refreshUsingBrowserLocation();
        }

        if (els.refreshBtn) els.refreshBtn.addEventListener('click', refreshUsingBrowserLocation);
        if (els.generateBtn) els.generateBtn.addEventListener('click', refreshUsingStoredOrBrowserLocation);

        refreshHistoryChart();
    </script>
}