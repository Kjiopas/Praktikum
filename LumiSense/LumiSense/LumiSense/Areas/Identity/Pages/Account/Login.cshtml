@page
@model LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<LumiSense.SharedResource> L
@{
    ViewData["Title"] = L["Login_Title"].Value;
}

<div class="hero" style="background: linear-gradient(135deg, #6a75d1, #7b5bbd); color:white; text-align:center; padding:3rem 1rem; border-radius:0 0 20px 20px;">
    <h1><i class="fas fa-microchip"></i> @L["Login_HeroTitle"]</h1>
    <p>@L["Login_HeroSubtitle"]</p>
</div>

<div class="container" style="max-width:400px; margin:2rem auto;">
    <div class="uv-card">
        <h2 style="text-align:center; margin-bottom:1.5rem;">@L["Login_SignIn"]</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <input asp-for="Input.Email" class="form-control" placeholder="@L["Common_Email"]" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input asp-for="Input.Password" class="form-control" placeholder="@L["Common_Password"]" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check" style="margin-top:1rem;">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
            </div>

            <button type="submit" class="buy-btn" style="width:100%; margin-top:1.5rem;">
                <i class="fas fa-sign-in-alt"></i> @L["Auth_Login"]
            </button>

            <p style="text-align:center; margin-top:1rem;">
                <a asp-page="./Register" style="color:#F27121;">@L["Login_DontHaveAccount"]</a><br />
                <a asp-page="./ForgotPassword" style="color:#F27121;">@L["Login_ForgotPassword"]</a><br />
                <a asp-page="./ResendEmailConfirmation" style="color:#F27121;">@L["Login_ResendEmailConfirmation"]</a>
            </p>
        </form>
    </div>
</div>